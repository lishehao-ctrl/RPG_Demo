APP_STORY_LIBRARY_DB_PATH=/srv/rpg-demo/data/story_library.sqlite3
APP_RUNTIME_STATE_DB_PATH=/srv/rpg-demo/data/runtime_state.sqlite3
APP_PLAY_SESSION_TTL_SECONDS=3600
APP_ENABLE_BENCHMARK_API=0
APP_DEFAULT_ACTOR_ID=local-dev
APP_AUTH_SESSION_COOKIE_SECURE=true
APP_AUTH_SESSION_COOKIE_SAMESITE=lax
APP_PUBLIC_DEMO_AUTHORING_ENABLED=false
APP_PUBLIC_DEMO_DAILY_IP_LLM_LIMIT=80
APP_PUBLIC_DEMO_DAILY_USER_LLM_LIMIT=24
APP_ROSTER_ENABLED=true
APP_ROSTER_SOURCE_CATALOG_PATH=/srv/rpg-demo/app/data/character_roster/catalog.json
APP_ROSTER_RUNTIME_CATALOG_PATH=/srv/rpg-demo/data/character_roster_runtime.json
APP_LOCAL_PORTRAIT_BASE_URL=https://rpg.shehao.app

APP_RESPONSES_BASE_URL=https://api.xcode.best/v1
APP_RESPONSES_API_KEY=replace_me_primary_key
APP_RESPONSES_API_KEYS=replace_me_primary_key,replace_me_secondary_key
APP_RESPONSES_MODEL=gpt-5.4-mini

APP_RESPONSES_AUTHOR_BASE_URL=https://api.xcode.best/v1
APP_RESPONSES_AUTHOR_API_KEY=replace_me_primary_key
APP_RESPONSES_AUTHOR_API_KEYS=replace_me_primary_key,replace_me_secondary_key
APP_RESPONSES_AUTHOR_MODEL=gpt-5.4-mini

APP_RESPONSES_PLAY_BASE_URL=https://api.xcode.best/v1
APP_RESPONSES_PLAY_API_KEY=replace_me_primary_key
APP_RESPONSES_PLAY_MODEL=gpt-5.4-mini
APP_RESPONSES_PLAY_API_KEYS=replace_me_primary_key,replace_me_secondary_key

# Helper judge/audit endpoint: single primary helper.
# If you have multiple API keys for the same provider, configure them in APP_HELPER_RESPONSES_API_KEYS
# and the runtime will random-sample across keys.
# APP_HELPER_SLOT_2_BASE_URL=https://api.xcode.best/v1
# APP_HELPER_SLOT_2_API_KEY=replace_me_primary_key
# APP_HELPER_SLOT_2_MODEL=gpt-5.4-mini
# APP_HELPER_SLOT_2_USE_SESSION_CACHE=false
# APP_HELPER_SLOT_2_ROLE=primary
# APP_HELPER_RESPONSES_API_KEYS=replace_me_key1,replace_me_key2
# APP_HELPER_RESPONSES_REQUESTS_PER_MINUTE=200
# APP_HELPER_RESPONSES_ENABLE_WEB_SEARCH=false

# Optional tuning
# APP_RESPONSES_TIMEOUT_SECONDS=20
# APP_RESPONSES_TIMEOUT_SECONDS_LLM_TEXT_AUDIT=60
# APP_RESPONSES_USE_SESSION_CACHE=true
# APP_RESPONSES_JSON_CONTENT_TYPE_HINT=false
# APP_RESPONSES_SESSION_CACHE_HEADER=x-dashscope-session-cache
# APP_RESPONSES_SESSION_CACHE_VALUE=enable
# APP_RESPONSES_PLAY_REQUESTS_PER_MINUTE=500
