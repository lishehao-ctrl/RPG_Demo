# ─────────────────────────────────────────────────────────────────────────
# Tiny Stories — example environment configuration
# ─────────────────────────────────────────────────────────────────────────
# Copy this to `.env` and fill in your values, OR set these as real
# environment variables.  All vars use the `APP_` prefix per pydantic-
# settings convention.
#
# REQUIRED to run end-to-end: a Responses-style LLM endpoint (any
# OpenAI-compatible API works — DashScope, OpenAI, DeepSeek, OpenRouter,
# any local server speaking the OpenAI protocol).
# ─────────────────────────────────────────────────────────────────────────


# ── LLM gateway (REQUIRED) ────────────────────────────────────────────────
# This drives every LLM call in the narrative engine: opening generation,
# turn advance, advisor, oracle, ending, highlights, branches, failure
# judge.  Use ANY OpenAI-compatible base_url + api_key.
#
# Example providers (pick one, comment the others):
#
# DashScope (Alibaba, qwen models):
#   APP_RESPONSES_PLAY_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
#   APP_RESPONSES_PLAY_MODEL=qwen3.6-flash
#
# OpenAI direct:
#   APP_RESPONSES_PLAY_BASE_URL=https://api.openai.com/v1
#   APP_RESPONSES_PLAY_MODEL=gpt-4o-mini
#
# Local (e.g. ollama with the openai-compatible adapter):
#   APP_RESPONSES_PLAY_BASE_URL=http://localhost:11434/v1
#   APP_RESPONSES_PLAY_MODEL=qwen2.5:14b
APP_RESPONSES_PLAY_BASE_URL=
APP_RESPONSES_PLAY_API_KEY=
APP_RESPONSES_PLAY_MODEL=

# Optional: separate API key pool used when the primary key hits rate
# limits — you can leave this empty and the engine will reuse the key
# above. Comma-separated list:
#   APP_RESPONSES_PLAY_API_KEYS=key1,key2,key3
APP_RESPONSES_PLAY_API_KEYS=


# ── Storage (default values work; only override if you want elsewhere) ──
APP_STORY_LIBRARY_DB_PATH=artifacts/story_library.sqlite3
APP_RUNTIME_STATE_DB_PATH=artifacts/runtime_state.sqlite3


# ── Auth cookies (defaults are fine for local dev) ────────────────────────
# Set SECURE=true and SAMESITE=none only when serving over HTTPS in prod.
APP_AUTH_SESSION_COOKIE_SECURE=false
APP_AUTH_SESSION_COOKIE_SAMESITE=lax


# ── LLM transport tuning (optional; defaults work) ────────────────────────
APP_RESPONSES_TIMEOUT_SECONDS=120
APP_RESPONSES_TRANSPORT_MODE=responses_api


# ── Optional features ─────────────────────────────────────────────────────
APP_PLAY_SESSION_TTL_SECONDS=86400
APP_ENABLE_BENCHMARK_API=false


# ── Notes ─────────────────────────────────────────────────────────────────
# - The dashscope keys committed in this repo's history are NOT mine to
#   share. You must obtain your own.
# - For local dev with cheap testing, qwen-flash class models cost ≈$0.05
#   per 12-turn session. GPT-4o-mini is roughly comparable. Plan accordingly.
# - The frontend reads no env vars at runtime — it talks to /narrative/
#   /auth/ etc through the Vite dev proxy (frontend2/vite.config.ts).
